NODE_ENV=development
HOST=127.0.0.1
PORT=3000
FRONTEND_URL=http://127.0.0.1:3000
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/phishguard

# Use two different 256-bit+ secrets in production.
JWT_SECRET=replace_with_a_long_random_256_bit_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_256_bit_secret

EMAIL_FROM=PhishGuard <no-reply@phishguard.local>
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

VIRUSTOTAL_API_KEY=replace_me
ABSTRACT_API_KEY=optional_replace_me
