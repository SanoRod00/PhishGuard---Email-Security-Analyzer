NODE_ENV=production
HOST=127.0.0.1
PORT=3000
FRONTEND_URL=https://phishguard.example.com
STORAGE_DRIVER=postgres
DATABASE_URL=postgres://phishguard:change_me@127.0.0.1:5432/phishguard

# Use two different long random secrets.
JWT_SECRET=replace_with_a_long_random_256_bit_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_256_bit_secret

EMAIL_FROM=PhishGuard <no-reply@phishguard.example.com>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=phishguard@example.com
SMTP_PASS=replace_with_real_smtp_password

VIRUSTOTAL_API_KEY=replace_me
ABSTRACT_API_KEY=optional_replace_me
